{
  "name": "next-app",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:start": "electron .",
    "electron:build": "next build && electron-builder"
  },
  "build": {
    "appId": "com.dreamtimetable.iit",
